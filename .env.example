# Mirror — Environment Variables Example
# Copy to `api/.env` and `web/.env` and fill in real values.
# Never commit `.env` — both paths are in `.gitignore`.

# ===== Backend (api/.env) ====================================================
# ElevenLabs — Instant Voice Cloning + Flash v2.5 TTS
# Sign up: https://elevenlabs.io  (Starter plan required for IVC + Mandarin)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_MODEL=eleven_flash_v2_5

# HuggingFace — Whisper Large V3 (server-side ASR fallback for Firefox /
# when browser Web Speech API errors out). Token: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_ASR_ENDPOINT=https://router.huggingface.co/hf-inference/models/openai/whisper-large-v3

# OpenAI — native-language tutor explanation under the DiagnosisCard
# AND the custom-sentence translation pipeline (/api/translate).
# Pricing: GPT-4o-mini is ~$0.0005/attempt. Set a usage limit on
# https://platform.openai.com/settings/organization/limits before deploy.
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini — kept as a silent backup for /api/explain. Not used
# by default; only if OPENAI_API_KEY is unset or OpenAI is unreachable.
# Free tier: 1500 requests/day. Key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional CORS lockdown — comma-separated origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ===== Frontend (web/.env) ===================================================
# Leave empty in production (Vercel same-origin); set to a URL for hybrid local dev.
VITE_API_BASE_URL=
