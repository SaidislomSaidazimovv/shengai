# ShengAI Environment Variables Example
# Copy this file to `api/.env` and `web/.env` and fill in real values.
# NEVER commit `.env` files with real keys — they are git-ignored.

# ===== Backend (api/.env) ===================================================
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PORT=8000

# ===== Frontend (web/.env) ==================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=ShengAI

# ----- Firebase (optional, enables sign-in + cross-device sync) -------------
# Console: https://console.firebase.google.com → Project Settings → Your apps
# Leave empty to disable Firebase entirely; the app falls back to localStorage.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
