# OVOZ — Environment Variables Example
# Copy to `api/.env` and `web/.env` and fill in real values.
# Never commit `.env` — both paths are in `.gitignore`.

# ===== Backend (api/.env) ====================================================
# ElevenLabs — Instant Voice Cloning + Flash v2.5 TTS
# Sign up: https://elevenlabs.io  (Starter plan required for IVC + Mandarin)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_MODEL=eleven_flash_v2_5

# HuggingFace — Whisper Large V3 (server-side ASR fallback for Firefox /
# when browser Web Speech API errors out). Token: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_ASR_ENDPOINT=https://api-inference.huggingface.co/models/openai/whisper-large-v3

# Optional CORS lockdown — comma-separated origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ===== Frontend (web/.env) ===================================================
# Leave empty in production (Vercel same-origin); set to a URL for hybrid local dev.
VITE_API_BASE_URL=
